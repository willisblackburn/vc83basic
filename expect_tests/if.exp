source [file join [file dirname [info script]] common.expinc]
spawn_basic

# IF

test {
NEW
10 PRINT 1
20 IF 0 THEN PRINT 2
30 IF 1 THEN PRINT 3
40 PRINT 4
50 END
RUN
} {
1
3
4
}

test {
NEW
10 PRINT 1
20 IF 0 THEN PRINT 2:PRINT 20
30 IF 1 THEN PRINT 3:PRINT 30
40 PRINT 4
50 END
RUN
} {
1
3
30
4
}
