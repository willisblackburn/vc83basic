source [file join [file dirname [info script]] common.expinc]

spawn_basic

# GOTO

test {
NEW
10 PRINT 1
20 GOTO 50
30 PRINT 3
40 END
50 PRINT 2
60 GOTO 30
RUN
} {
1
2
3
}

# Missing line number

test {
NEW
10 PRINT 1
20 GOTO 40
30 END
RUN
} {
1

ERROR: LINE? AT 20
}

# ON...GOTO

test {
NEW
10 PRINT 1
20 ON 0 GOTO 50,60,70
30 PRINT 2
40 END
50 PRINT 3
60 PRINT 4
70 PRINT 5
RUN
} {
1
2
}

test {
NEW
10 PRINT 1
20 ON 1 GOTO 50,60,70
30 PRINT 2
40 END
50 PRINT 3
60 PRINT 4
70 PRINT 5
RUN
} {
1
3
4
5
}

test {
NEW
10 PRINT 1
20 ON 2 GOTO 50,60,70
30 PRINT 2
40 END
50 PRINT 3
60 PRINT 4
70 PRINT 5
RUN
} {
1
4
5
}

test {
NEW
10 PRINT 1
20 ON 3 GOTO 50,60,70
30 PRINT 2
40 END
50 PRINT 3
60 PRINT 4
70 PRINT 5
RUN
} {
1
5
}

test {
NEW
10 PRINT 1
20 ON 4 GOTO 50,60,70
30 PRINT 2
40 END
50 PRINT 3
60 PRINT 4
70 PRINT 5
RUN
} {
1

ERROR: RANGE AT 20
}

test {
NEW
10 PRINT 1
20 ON 1000 GOTO 50,60,70
30 PRINT 2
40 END
50 PRINT 3
60 PRINT 4
70 PRINT 5
RUN
} {
1

ERROR: RANGE AT 20
}

test {
NEW
10 PRINT 1
20 ON -1 GOTO 50,60,70
30 PRINT 2
40 END
50 PRINT 3
60 PRINT 4
70 PRINT 5
RUN
} {
1

ERROR: RANGE AT 20
}
