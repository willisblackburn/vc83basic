source [file join [file dirname [info script]] common.expinc]
spawn_basic

# ASC

test {
PRINT ASC("A")
} {
65
}

# CHR$

test {
PRINT CHR$(65)
} {
A
}

# LEFT$, RIGHT$, MID$

test {
PRINT LEFT$("HELLO",2)
} {
HE
}

test {
PRINT LEFT$("HELLO",100)
} {
HELLO
}

test {
PRINT LEFT$("HELLO",0)
} {

}

test {
PRINT LEFT$("HELLO",-1)
} {
ERR: RANGE
}

test {
PRINT RIGHT$("HELLO",2)
} {
LO
}

test {
PRINT RIGHT$("HELLO",100)
} {
HELLO
}

test {
PRINT RIGHT$("HELLO",0)
} {

}

test {
PRINT RIGHT$("HELLO",-1)
} {
ERR: RANGE
}

test {
PRINT MID$("HELLO",2,3)
} {
ELL
}

test {
PRINT MID$("HELLO",1,100)
} {
ELLO
}

test {
PRINT MID$("HELLO",1,0)
} {

}

test {
PRINT MID$("HELLO",1,-1)
} {
ERR: RANGE
}

test {
PRINT MID$("HELLO",0,1)
} {
ERR: RANGE
}

test {
PRINT MID$("HELLO",-1,1)
} {
ERR: RANGE
}

test {
LET H$="HELLO"
PRINT LEFT$(H$,1)&MID$(H$,2,3)&RIGHT$(H$,1)
} {
HELLO
}

# LEN

test {
PRINT LEN("HELLO")
} {
5
}

# STR$

test {
PRINT STR$(25)
} {
25
}

test {
PRINT STR$(3.14159)
} {
3.14159
}

# VAL

test {
PRINT VAL("3.14159")
} {
3.14159
}

# INT, ROUND, ABS, SGN

test {
PRINT INT(3.9), INT(-3.1), INT(-3.9)
} {
3               -3              -3
}

test {
PRINT ROUND(3.4), ROUND(3.5), ROUND(-3.4), ROUND(-3.5)
} {
3               4               -3              -4
}

test {
PRINT ABS(3.14), ABS(-3.14), ABS(0)
} {
3.14            3.14            0
}

test {
PRINT SGN(5), SGN(-5), SGN(0)
} {
1               -1              0
}

# FRE
# TODO: FRE(0) returns negative value in sim65 due to 16-bit signed integer limits.
# test {
# PRINT FRE(0) > 0
# } {
# 1
# }

# RND

test {
PRINT RND(1) >= 0 AND RND(1) < 1
} {
1
}

test {
LET R1=RND(1): LET R2=RND(1): PRINT R1<>R2
} {
1
}

test {
PRINT RND(0) = RND(0)
} {
1
}

# test {
# PRINT RND(-1) <> RND(-2)
# } {
# 1
# }
# TODO: RND(-1) and RND(-2) produce the same seed because they have the same normalized mantissa.
