source [file join [file dirname [info script]] common.expinc]
spawn_basic

# LIST

# Formatting of expressions in LIST

test {
NEW
100 PRINT 1
101 PRINT X
102 PRINT X+1
103 PRINT (X+1)*3
104 PRINT (X-1)/3
105 PRINT -X
106 PRINT -X+1
107 PRINT -X+(-1)
108 PRINT (-X+1)*3
109 PRINT (-X+1)/3
110 PRINT 1 AND 2
111 PRINT (X+1) AND 2
112 PRINT X,Y
113 PRINT X;Y
114 PRINT X,,Y
115 PRINT ,,X,;
116 PRINT "HELLO"
117 PRINT "HELLO"&"WORLD"
118 PRINT "HELLO" AND "WORLD"
LIST
} {
100 PRINT 1
101 PRINT X
102 PRINT X+1
103 PRINT (X+1)*3
104 PRINT (X-1)/3
105 PRINT -X
106 PRINT -X+1
107 PRINT -X+(-1)
108 PRINT (-X+1)*3
109 PRINT (-X+1)/3
110 PRINT 1 AND 2
111 PRINT (X+1) AND 2
112 PRINT X,Y
113 PRINT X;Y
114 PRINT X,,Y
115 PRINT ,,X,;
116 PRINT "HELLO"
117 PRINT "HELLO"&"WORLD"
118 PRINT "HELLO" AND "WORLD"
}

# DATA and REM retain all characters

test {
10 DATA 1,2,3
20 DATA TEXT WITHOUT QUOTES, "TEXT WITH QUOTES", 3.14159, !@#
LIST
} {
10 DATA 1,2,3
20 DATA TEXT WITHOUT QUOTES, "TEXT WITH QUOTES", 3.14159, !@#
}
