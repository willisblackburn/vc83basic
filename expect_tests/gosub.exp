source [file join [file dirname [info script]] common.expinc]
spawn_basic

# GOSUB

test {
NEW
10 PRINT 1
20 GOSUB 50
30 PRINT 3
40 END
50 PRINT 2
60 RETURN
RUN
} {
1
2
3
}

# Missing line number

test {
NEW
10 PRINT 1
20 GOSUB 40
30 END
RUN
} {
1

ERROR: LINE? AT 20
}

# RETURN without GOSUB

test {
NEW
10 GOSUB 20
20 PRINT 1
30 RETURN
RUN
} {
1
1

ERROR: NO GOSUB AT 30
}

# Infinite GOSUB (will eventually run out of stack space, may have to adjust test if changing stack size)

test {
NEW
10 PRINT 1
20 PRINT 2
30 GOSUB 20
RUN
} {
1
2
2
2
2
2
2
2
2
2
2
2
2

ERROR: O'FLOW AT 20
}

# ON...GOSUB

test {
NEW
10 PRINT 1
20 ON 0 GOSUB 50,60,70
30 PRINT 2
40 END
50 PRINT 3
60 PRINT 4
70 PRINT 5
80 RETURN
RUN
} {
1
2
}

test {
NEW
10 PRINT 1
20 ON 1 GOSUB 50,60,70
30 PRINT 2
40 END
50 PRINT 3
60 PRINT 4
70 PRINT 5
80 RETURN
RUN
} {
1
3
4
5
2
}

test {
NEW
10 PRINT 1
20 ON 2 GOSUB 50,60,70
30 PRINT 2
40 END
50 PRINT 3
60 PRINT 4
70 PRINT 5
80 RETURN
RUN
} {
1
4
5
2
}

test {
NEW
10 PRINT 1
20 ON 3 GOSUB 50,60,70
30 PRINT 2
40 END
50 PRINT 3
60 PRINT 4
70 PRINT 5
80 RETURN
RUN
} {
1
5
2
}

test {
NEW
10 PRINT 1
20 ON 4 GOSUB 50,60,70
30 PRINT 2
40 END
50 PRINT 3
60 PRINT 4
70 PRINT 5
80 RETURN
RUN
} {
1

ERROR: RANGE AT 20
}

test {
NEW
10 PRINT 1
20 ON 1000 GOSUB 50,60,70
30 PRINT 2
40 END
50 PRINT 3
60 PRINT 4
70 PRINT 5
80 RETURN
RUN
} {
1

ERROR: RANGE AT 20
}

test {
NEW
10 PRINT 1
20 ON -1 GOSUB 50,60,70
30 PRINT 2
40 END
50 PRINT 3
60 PRINT 4
70 PRINT 5
80 RETURN
RUN
} {
1

ERROR: RANGE AT 20
}

# POP

test {
NEW
10 GOSUB 20
20 PRINT 1
30 POP
40 RETURN
RUN
} {
1

ERROR: NO GOSUB AT 40
}

# POP without GOSUB

test {
NEW
10 PRINT 1
20 POP
RUN
} {
1

ERROR: U'FLOW AT 20
}
